# Appwrite Configuration
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your-project-id-here
EXPO_PUBLIC_APPWRITE_DATABASE_ID=stitch-and-wear-db
EXPO_PUBLIC_APPWRITE_STORAGE_ID=stitch-and-wear-storage

# Server-side API Key (for database setup script)
APPWRITE_API_KEY=your-api-key-here

# For the setup script (can be same as above)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id-here

# OAuth Configuration - Google
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# OAuth Configuration - Facebook
EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
EXPO_PUBLIC_FACEBOOK_APP_SECRET=your-facebook-app-secret

# SMS Configuration - Twilio
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=your-twilio-account-sid
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=your-twilio-auth-token
EXPO_PUBLIC_TWILIO_PHONE_NUMBER=+1234567890
EXPO_PUBLIC_TWILIO_VERIFY_SERVICE_ID=your-verify-service-id

# Security Keys
EXPO_PUBLIC_JWT_SECRET=your-jwt-secret-key-min-32-chars
EXPO_PUBLIC_ENCRYPTION_KEY=your-encryption-key-min-32-chars

# Password Recovery Configuration
EXPO_PUBLIC_PASSWORD_RECOVERY_URL=https://your-domain.com/reset-password

#TEST CREDENTIALS
ADMIN=admin@stitchandwear.com / Admin@123456
TAILOR=tailor@stitchandwear.com / Tailor@123456
CLIENT=client@stitchandwear.com / Client@123456